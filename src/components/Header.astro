---
const navLinks = [
  { href: "/assurance-auto/", label: "Assurance Auto" },
  { href: "/assurance-habitation/", label: "Assurance Habitation" },
  { href: "/mutuelle-sante/", label: "Mutuelle Santé" },
  { href: "/assurance-emprunteur/", label: "Assurance Emprunteur" },
  { href: "/reglementation/", label: "Réglementation" },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-40 w-full bg-white border-b border-gray-100">
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3 lg:px-6">
    <!-- Logo -->
    <a href="/" class="text-2xl font-bold text-coral tracking-tight hover:text-coral-dark transition-colors">
      Covelia
    </a>

    <!-- Desktop nav -->
    <ul class="hidden lg:flex items-center gap-1">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={[
              "px-3 py-2 rounded-lg text-sm font-medium transition-colors",
              currentPath.startsWith(link.href)
                ? "text-coral bg-coral-light/40"
                : "text-navy hover:text-coral hover:bg-coral-light/20",
            ]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Mobile hamburger (CSS-only) -->
    <input type="checkbox" id="mobile-menu-toggle" class="peer hidden" aria-hidden="true" />
    <label
      for="mobile-menu-toggle"
      class="relative z-50 flex h-10 w-10 cursor-pointer items-center justify-center rounded-lg hover:bg-gray-100 lg:hidden"
      aria-label="Ouvrir le menu"
    >
      <!-- Hamburger lines -->
      <span class="hamburger-icon relative block h-5 w-6">
        <span class="absolute left-0 top-0 block h-0.5 w-full rounded bg-navy transition-all duration-300 peer-checked:top-2 peer-checked:rotate-45"></span>
        <span class="absolute left-0 top-2 block h-0.5 w-full rounded bg-navy transition-all duration-300 peer-checked:opacity-0"></span>
        <span class="absolute left-0 top-4 block h-0.5 w-full rounded bg-navy transition-all duration-300 peer-checked:top-2 peer-checked:-rotate-45"></span>
      </span>
    </label>

    <!-- Mobile menu overlay -->
    <div class="fixed inset-0 z-40 hidden bg-black/20 peer-checked:block lg:!hidden" aria-hidden="true">
      <label for="mobile-menu-toggle" class="absolute inset-0"></label>
    </div>

    <!-- Mobile menu panel -->
    <div class="fixed top-0 right-0 z-40 h-full w-72 translate-x-full bg-white shadow-xl transition-transform duration-300 peer-checked:translate-x-0 lg:!hidden">
      <div class="flex items-center justify-between border-b border-gray-100 px-4 py-3">
        <span class="text-xl font-bold text-coral">Covelia</span>
        <label for="mobile-menu-toggle" class="flex h-10 w-10 cursor-pointer items-center justify-center rounded-lg hover:bg-gray-100" aria-label="Fermer le menu">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-navy" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </label>
      </div>
      <ul class="flex flex-col px-2 py-4">
        {navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class:list={[
                "block rounded-lg px-4 py-3 text-sm font-medium transition-colors",
                currentPath.startsWith(link.href)
                  ? "text-coral bg-coral-light/40"
                  : "text-navy hover:text-coral hover:bg-coral-light/20",
              ]}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </nav>
</header>

<style>
  /* CSS-only hamburger animation via sibling selector */
  #mobile-menu-toggle:checked ~ label .hamburger-icon span:nth-child(1) {
    top: 0.5rem;
    transform: rotate(45deg);
  }
  #mobile-menu-toggle:checked ~ label .hamburger-icon span:nth-child(2) {
    opacity: 0;
  }
  #mobile-menu-toggle:checked ~ label .hamburger-icon span:nth-child(3) {
    top: 0.5rem;
    transform: rotate(-45deg);
  }
</style>
