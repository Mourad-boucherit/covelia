---
const guideLinks = [
  { href: "/assurance-auto", label: "Assurance Auto" },
  { href: "/assurance-habitation", label: "Assurance Habitation" },
  { href: "/mutuelle-sante", label: "Mutuelle Sant\u00e9" },
  { href: "/assurance-emprunteur", label: "Assurance Emprunteur" },
  { href: "/reglementation", label: "R\u00e9glementation" },
];

const infoLinks = [
  { href: "/mentions-legales", label: "Mentions l\u00e9gales" },
  { href: "/politique-de-confidentialite", label: "Politique de confidentialit\u00e9" },
  { href: "/politique-de-transparence", label: "Politique de transparence" },
  { href: "/a-propos", label: "Qui sommes-nous" },
];

const socialLinks = [
  { href: "#", label: "TikTok", icon: "tiktok" },
  { href: "#", label: "Instagram", icon: "instagram" },
  { href: "#", label: "LinkedIn", icon: "linkedin" },
  { href: "#", label: "YouTube", icon: "youtube" },
];
---

<footer class="bg-navy-dark text-white">
  <div class="mx-auto max-w-6xl px-4 py-12 lg:px-6 lg:py-16">
    <div class="grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-4">

      <!-- Col 1: Brand -->
      <div class="sm:col-span-2 lg:col-span-1">
        <a href="/" class="text-2xl font-bold text-coral">Covelia</a>
        <p class="mt-3 text-sm leading-relaxed text-gray-400">
          Guides d'assurance ind&eacute;pendants.<br />
          Des conseils clairs et transparents pour vous aider &agrave; choisir la bonne couverture.
        </p>
      </div>

      <!-- Col 2: Guides -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-gray-300">Nos guides</h3>
        <ul class="mt-4 space-y-2.5">
          {guideLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-gray-400 transition-colors hover:text-coral">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Col 3: Informations -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-gray-300">Informations</h3>
        <ul class="mt-4 space-y-2.5">
          {infoLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-gray-400 transition-colors hover:text-coral">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Col 4: Social -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-gray-300">Suivez-nous</h3>
        <ul class="mt-4 flex gap-3">
          {socialLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="flex h-9 w-9 items-center justify-center rounded-lg bg-navy-light text-gray-400 transition-colors hover:bg-coral hover:text-white"
                aria-label={link.label}
                target="_blank"
                rel="noopener noreferrer"
              >
                {link.icon === "tiktok" && (
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1v-3.5a6.37 6.37 0 00-.79-.05A6.34 6.34 0 003.15 15.2a6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.34-6.34V8.71a8.19 8.19 0 004.76 1.52V6.78a4.86 4.86 0 01-1-.09z"/>
                  </svg>
                )}
                {link.icon === "instagram" && (
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
                  </svg>
                )}
                {link.icon === "linkedin" && (
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                  </svg>
                )}
                {link.icon === "youtube" && (
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
                  </svg>
                )}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-navy-light">
    <div class="mx-auto max-w-6xl px-4 py-5 lg:px-6">
      <div class="flex flex-col items-center gap-3 text-center sm:flex-row sm:justify-between sm:text-left">
        <p class="text-xs text-gray-500">
          &copy; 2026 Covelia.fr &mdash; Tous droits r&eacute;serv&eacute;s
        </p>
        <p class="max-w-lg text-xs leading-relaxed text-gray-500">
          Certains liens pr&eacute;sents sur ce site sont des liens d'affiliation. Covelia peut percevoir une commission sans co&ucirc;t suppl&eacute;mentaire pour vous. Cela n'influence pas nos recommandations.
        </p>
      </div>
    </div>
  </div>
</footer>
