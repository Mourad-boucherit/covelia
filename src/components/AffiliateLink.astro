---
interface Props {
  href: string;
  label: string;
  partner?: string;
}

const { href, label, partner } = Astro.props;
---

<a
  href={href}
  rel="nofollow sponsored"
  target="_blank"
  title={partner ? `Voir l'offre ${partner}` : undefined}
  class="inline-flex items-center gap-1 text-coral-dark font-medium underline underline-offset-2 decoration-coral/40 hover:decoration-coral hover:text-coral transition-colors"
>
  <span>{label}</span>
  <svg
    class="h-3.5 w-3.5 shrink-0"
    xmlns="http://www.w3.org/2000/svg"
    fill="none"
    viewBox="0 0 24 24"
    stroke-width="2.5"
    stroke="currentColor"
    aria-hidden="true"
  >
    <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" />
  </svg>
</a>
