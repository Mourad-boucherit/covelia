---
interface Props {
  title?: string;
  description?: string;
  links: Array<{ label: string; href: string; partner: string }>;
}

const {
  title = "Comparez les offres",
  description = "Trouvez la meilleure assurance au meilleur prix grâce à nos partenaires comparateurs.",
  links,
} = Astro.props;
---

<div class="my-10 max-w-2xl mx-auto rounded-2xl border-2 border-coral bg-white shadow-sm overflow-hidden">
  <div class="px-6 py-6 text-center">
    <h3 class="text-xl font-bold text-navy mb-2">{title}</h3>
    {description && (
      <p class="text-navy-light text-sm leading-relaxed mb-5">{description}</p>
    )}
    <div class="flex flex-wrap justify-center gap-3">
      {links.map((link) => (
        <a
          href={link.href}
          rel="nofollow sponsored"
          target="_blank"
          title={`Comparer sur ${link.partner}`}
          class="inline-flex items-center gap-2 rounded-lg bg-coral px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-coral-dark transition-colors"
        >
          <span>{link.label}</span>
          <svg
            class="h-4 w-4 shrink-0"
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2.5"
            stroke="currentColor"
            aria-hidden="true"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" />
          </svg>
        </a>
      ))}
    </div>
  </div>
</div>
