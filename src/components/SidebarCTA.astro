---
import { getPartnersForCategory } from '../data/affiliates';

interface Props {
  category: string;
}

const { category } = Astro.props;
const partners = getPartnersForCategory(category);
const mainPartner = partners.find((p) => p.slug === 'assurland') || partners[0];
---

{mainPartner && (
  <div class="rounded-xl border-2 border-coral bg-white p-3 shadow-sm">
    <p class="text-xs font-bold text-navy mb-2">Comparez les assurances</p>
    <a
      href={mainPartner.url}
      rel="nofollow sponsored"
      target="_blank"
      title={`Comparer sur ${mainPartner.name}`}
      class="flex items-center justify-center gap-2 rounded-lg bg-coral px-4 py-2 text-sm font-semibold text-white transition-colors hover:bg-coral-dark"
    >
      <span>{mainPartner.name}</span>
      <svg
        class="h-3.5 w-3.5 shrink-0"
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke-width="2.5"
        stroke="currentColor"
        aria-hidden="true"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" />
      </svg>
    </a>
    <p class="mt-2 text-[10px] text-gray-400 leading-tight">
      Lien affilié — sans surcoût pour vous.
    </p>
  </div>
)}
