---
interface Props {
  type?: 'tip' | 'warning' | 'info' | 'important';
  title?: string;
}

const { type = 'info', title } = Astro.props;

const styles = {
  tip: {
    bg: 'bg-coral-light/30',
    border: 'border-coral',
    icon: `<svg class="h-5 w-5 text-coral shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18v-5.25m0 0a6.01 6.01 0 0 0 1.5-.189m-1.5.189a6.01 6.01 0 0 1-1.5-.189m3.75 7.478a12.06 12.06 0 0 1-4.5 0m3.75 2.383a14.406 14.406 0 0 1-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 1 0-7.517 0c.85.493 1.509 1.333 1.509 2.316V18" /></svg>`,
    defaultTitle: 'Bon à savoir',
  },
  info: {
    bg: 'bg-slate-100',
    border: 'border-slate-300',
    icon: `<svg class="h-5 w-5 text-slate-500 shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m11.25 11.25.041-.02a.75.75 0 0 1 1.063.852l-.708 2.836a.75.75 0 0 0 1.063.853l.041-.021M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9-3.75h.008v.008H12V8.25Z" /></svg>`,
    defaultTitle: 'Information',
  },
  warning: {
    bg: 'bg-amber-50',
    border: 'border-amber-400',
    icon: `<svg class="h-5 w-5 text-amber-500 shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" /></svg>`,
    defaultTitle: 'Attention',
  },
  important: {
    bg: 'bg-coral-light/50',
    border: 'border-coral-dark',
    icon: `<svg class="h-5 w-5 text-coral-dark shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" /></svg>`,
    defaultTitle: 'Important',
  },
};

const s = styles[type];
const displayTitle = title || s.defaultTitle;
---

<aside class={`not-prose rounded-xl border-l-4 ${s.border} ${s.bg} px-5 py-4 my-8`} role="note">
  <div class="flex items-start gap-3">
    <Fragment set:html={s.icon} />
    <div>
      <p class="font-semibold text-navy text-sm mb-1">{displayTitle}</p>
      <div class="text-sm text-navy-light leading-relaxed">
        <slot />
      </div>
    </div>
  </div>
</aside>
