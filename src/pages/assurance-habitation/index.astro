---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const articles = await getCollection("assurance-habitation");

const sortedArticles = articles.sort(
  (a, b) =>
    new Date(b.data.datePublished).getTime() -
    new Date(a.data.datePublished).getTime()
);

const categoryTitle = "Assurance Habitation";
const categorySlug = "assurance-habitation";
const categoryDescription =
  "Guides complets et conseils pour protéger votre logement. Tout savoir sur l'assurance habitation en France : garanties, sinistres, tarifs et obligations légales.";
---

<BaseLayout
  title={`${categoryTitle} : guides et comparatifs | Covelia.fr`}
  description={categoryDescription}
>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12">
    <!-- Breadcrumbs -->
    <nav aria-label="Fil d'Ariane" class="mb-8">
      <ol class="flex items-center gap-2 text-sm text-navy-light">
        <li>
          <a href="/" class="hover:text-coral transition-colors">Accueil</a>
        </li>
        <li aria-hidden="true" class="select-none">/</li>
        <li class="text-navy font-medium" aria-current="page">
          {categoryTitle}
        </li>
      </ol>
    </nav>

    <!-- Hero -->
    <header class="mb-16">
      <h1 class="text-4xl sm:text-5xl font-bold text-navy mb-6">
        {categoryTitle}
      </h1>
      <p class="text-xl text-navy-light max-w-3xl leading-relaxed">
        {categoryDescription}
      </p>
    </header>

    <!-- Introduction / Pillar content area -->
    <section class="mb-16 max-w-3xl">
      <div class="prose prose-lg prose-headings:text-navy prose-a:text-coral">
        <p>
          L'assurance habitation protège votre logement et vos biens contre les
          risques du quotidien : incendie, dégât des eaux, vol, catastrophe
          naturelle. Obligatoire pour les locataires et fortement recommandée
          pour les propriétaires, elle est un pilier essentiel de votre
          protection patrimoniale. Découvrez nos guides pour choisir la
          meilleure couverture.
        </p>
        <!-- Placeholder for pillar content: 500+ words of editorial content will be added here -->
      </div>
    </section>

    <!-- Articles grid -->
    {sortedArticles.length > 0 && (
      <section aria-labelledby="articles-heading" class="mb-16">
        <h2
          id="articles-heading"
          class="text-2xl sm:text-3xl font-bold text-navy mb-8"
        >
          Tous nos articles
        </h2>
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {sortedArticles.map((entry) => {
            const formattedDate = new Date(
              entry.data.datePublished
            ).toLocaleDateString("fr-FR", {
              year: "numeric",
              month: "long",
              day: "numeric",
            });
            return (
              <a
                href={`/${categorySlug}/${entry.id}/`}
                class="group flex flex-col rounded-xl border border-gray-200 p-6 transition-all hover:border-coral hover:shadow-lg"
              >
                <h3 class="text-lg font-semibold text-navy group-hover:text-coral transition-colors line-clamp-2">
                  {entry.data.title}
                </h3>
                <p class="mt-3 text-sm text-navy-light line-clamp-3 flex-1">
                  {entry.data.description}
                </p>
                <div class="mt-4 flex items-center gap-3 text-xs text-navy-light">
                  <time datetime={entry.data.datePublished.toISOString()}>
                    {formattedDate}
                  </time>
                  {entry.data.estimatedReadingTime && (
                    <>
                      <span aria-hidden="true">·</span>
                      <span>{entry.data.estimatedReadingTime} min de lecture</span>
                    </>
                  )}
                </div>
              </a>
            );
          })}
        </div>
      </section>
    )}

    <!-- FAQ section placeholder -->
    <section aria-labelledby="faq-heading" class="mb-16 max-w-3xl">
      <h2
        id="faq-heading"
        class="text-2xl sm:text-3xl font-bold text-navy mb-8"
      >
        Questions fréquentes
      </h2>
      <div class="space-y-6">
        <details class="group rounded-xl border border-gray-200 p-5">
          <summary class="cursor-pointer font-semibold text-navy group-open:text-coral transition-colors">
            L'assurance habitation est-elle obligatoire ?
          </summary>
          <p class="mt-3 text-navy-light leading-relaxed">
            Oui, pour les locataires d'un logement non meublé, l'assurance
            habitation est obligatoire (loi du 6 juillet 1989). Pour les
            propriétaires, elle est très fortement recommandée bien que non
            obligatoire (sauf en copropriété depuis la loi Alur).
          </p>
        </details>
        <details class="group rounded-xl border border-gray-200 p-5">
          <summary class="cursor-pointer font-semibold text-navy group-open:text-coral transition-colors">
            Que couvre une assurance habitation multirisque ?
          </summary>
          <p class="mt-3 text-navy-light leading-relaxed">
            Une assurance multirisque habitation (MRH) couvre généralement les
            dommages liés à l'incendie, au dégât des eaux, au vol, au
            vandalisme, aux catastrophes naturelles et à la responsabilité
            civile vie privée.
          </p>
        </details>
        <details class="group rounded-xl border border-gray-200 p-5">
          <summary class="cursor-pointer font-semibold text-navy group-open:text-coral transition-colors">
            Comment déclarer un sinistre habitation ?
          </summary>
          <p class="mt-3 text-navy-light leading-relaxed">
            Vous disposez de 5 jours ouvrés (2 jours pour un vol) après la
            découverte du sinistre pour le déclarer à votre assureur. La
            déclaration peut se faire par courrier recommandé, en ligne ou par
            téléphone selon votre contrat.
          </p>
        </details>
      </div>
    </section>
  </div>
</BaseLayout>
