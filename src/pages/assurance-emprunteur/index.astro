---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const articles = await getCollection("assurance-emprunteur");

const sortedArticles = articles.sort(
  (a, b) =>
    new Date(b.data.datePublished).getTime() -
    new Date(a.data.datePublished).getTime()
);

const categoryTitle = "Assurance Emprunteur";
const categorySlug = "assurance-emprunteur";
const categoryDescription =
  "Tout comprendre sur l'assurance de prêt immobilier. Guides sur la délégation d'assurance, la loi Lemoine, les garanties et les économies possibles.";
---

<BaseLayout
  title={`${categoryTitle} : guides et comparatifs | Covelia.fr`}
  description={categoryDescription}
>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12">
    <!-- Breadcrumbs -->
    <nav aria-label="Fil d'Ariane" class="mb-8">
      <ol class="flex items-center gap-2 text-sm text-navy-light">
        <li>
          <a href="/" class="hover:text-coral transition-colors">Accueil</a>
        </li>
        <li aria-hidden="true" class="select-none">/</li>
        <li class="text-navy font-medium" aria-current="page">
          {categoryTitle}
        </li>
      </ol>
    </nav>

    <!-- Hero -->
    <header class="mb-16">
      <h1 class="text-4xl sm:text-5xl font-bold text-navy mb-6">
        {categoryTitle}
      </h1>
      <p class="text-xl text-navy-light max-w-3xl leading-relaxed">
        {categoryDescription}
      </p>
    </header>

    <!-- Introduction / Pillar content area -->
    <section class="mb-16 max-w-3xl">
      <div class="prose prose-lg prose-headings:text-navy prose-a:text-coral">
        <p>
          L'assurance emprunteur est une garantie incontournable lors de la
          souscription d'un prêt immobilier. Depuis la loi Lemoine de 2022, vous
          pouvez changer d'assurance de prêt à tout moment et sans frais.
          Découvrez comment optimiser cette assurance qui peut représenter
          jusqu'à 30 % du coût total de votre crédit immobilier.
        </p>
        <!-- Placeholder for pillar content: 500+ words of editorial content will be added here -->
      </div>
    </section>

    <!-- Articles grid -->
    {sortedArticles.length > 0 && (
      <section aria-labelledby="articles-heading" class="mb-16">
        <h2
          id="articles-heading"
          class="text-2xl sm:text-3xl font-bold text-navy mb-8"
        >
          Tous nos articles
        </h2>
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {sortedArticles.map((entry) => {
            const formattedDate = new Date(
              entry.data.datePublished
            ).toLocaleDateString("fr-FR", {
              year: "numeric",
              month: "long",
              day: "numeric",
            });
            return (
              <a
                href={`/${categorySlug}/${entry.id}/`}
                class="group flex flex-col rounded-xl border border-gray-200 p-6 transition-all hover:border-coral hover:shadow-lg"
              >
                <h3 class="text-lg font-semibold text-navy group-hover:text-coral transition-colors line-clamp-2">
                  {entry.data.title}
                </h3>
                <p class="mt-3 text-sm text-navy-light line-clamp-3 flex-1">
                  {entry.data.description}
                </p>
                <div class="mt-4 flex items-center gap-3 text-xs text-navy-light">
                  <time datetime={entry.data.datePublished.toISOString()}>
                    {formattedDate}
                  </time>
                  {entry.data.estimatedReadingTime && (
                    <>
                      <span aria-hidden="true">·</span>
                      <span>{entry.data.estimatedReadingTime} min de lecture</span>
                    </>
                  )}
                </div>
              </a>
            );
          })}
        </div>
      </section>
    )}

    <!-- FAQ section placeholder -->
    <section aria-labelledby="faq-heading" class="mb-16 max-w-3xl">
      <h2
        id="faq-heading"
        class="text-2xl sm:text-3xl font-bold text-navy mb-8"
      >
        Questions fréquentes
      </h2>
      <div class="space-y-6">
        <details class="group rounded-xl border border-gray-200 p-5">
          <summary class="cursor-pointer font-semibold text-navy group-open:text-coral transition-colors">
            L'assurance emprunteur est-elle obligatoire ?
          </summary>
          <p class="mt-3 text-navy-light leading-relaxed">
            Légalement non, mais dans la pratique, aucune banque n'accorde de
            prêt immobilier sans assurance emprunteur. Elle protège à la fois
            l'emprunteur et la banque en cas de décès, d'invalidité ou
            d'incapacité de travail.
          </p>
        </details>
        <details class="group rounded-xl border border-gray-200 p-5">
          <summary class="cursor-pointer font-semibold text-navy group-open:text-coral transition-colors">
            Qu'est-ce que la loi Lemoine ?
          </summary>
          <p class="mt-3 text-navy-light leading-relaxed">
            La loi Lemoine (2022) permet de changer d'assurance emprunteur à
            tout moment, sans frais et sans attendre la date anniversaire du
            contrat. Elle supprime aussi le questionnaire médical pour les prêts
            de moins de 200 000 euros par assuré.
          </p>
        </details>
        <details class="group rounded-xl border border-gray-200 p-5">
          <summary class="cursor-pointer font-semibold text-navy group-open:text-coral transition-colors">
            Combien peut-on économiser en changeant d'assurance emprunteur ?
          </summary>
          <p class="mt-3 text-navy-light leading-relaxed">
            En optant pour une délégation d'assurance (assureur externe plutôt
            que celui de la banque), les économies peuvent atteindre 50 % à 70 %
            sur le coût total de l'assurance, soit plusieurs milliers d'euros
            sur la durée du prêt.
          </p>
        </details>
      </div>
    </section>
  </div>
</BaseLayout>
