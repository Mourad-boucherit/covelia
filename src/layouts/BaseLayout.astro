---
interface Props {
  title: string;
  description: string;
  image?: string;
  canonicalUrl?: string;
}

const { title, description, image, canonicalUrl } = Astro.props;

import "../styles/global.css";
import SEOHead from "../components/SEOHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<!doctype html>
<html lang="fr" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Google Analytics - Consent Mode v2 (RGPD) -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}

      // Défaut : tout refusé jusqu'au consentement
      gtag('consent', 'default', {
        analytics_storage: 'denied',
        ad_storage: 'denied',
        ad_user_data: 'denied',
        ad_personalization: 'denied',
        wait_for_update: 500
      });

      // Si déjà accepté lors d'une visite précédente
      if (localStorage.getItem('covelia_consent') === 'granted') {
        gtag('consent', 'update', {
          analytics_storage: 'granted'
        });
      }

      gtag('js', new Date());
      gtag('config', 'G-B3J05XJSDJ', {
        anonymize_ip: true,
        cookie_flags: 'SameSite=None;Secure'
      });
    </script>
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-B3J05XJSDJ"></script>

    <SEOHead
      title={title}
      description={description}
      canonicalUrl={canonicalUrl}
      image={image}
    />

    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-white text-navy font-sans antialiased">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:rounded-lg focus:bg-coral focus:px-4 focus:py-2 focus:text-white focus:outline-none"
    >
      Aller au contenu principal
    </a>

    <Header />

    <main id="main-content">
      <slot />
    </main>

    <Footer />

    <!-- Bandeau cookies RGPD -->
    <style>
      #cookie-banner {
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        z-index: 50;
        background: #1E293B;
        color: #fff;
        padding: 1rem;
        box-shadow: 0 -2px 10px rgba(0,0,0,.2);
        transform: translateY(100%);
        transition: transform .4s ease;
      }
      #cookie-banner.visible {
        transform: translateY(0);
      }
    </style>
    <div id="cookie-banner" role="dialog" aria-label="Gestion des cookies">
      <div class="max-w-4xl mx-auto flex flex-col sm:flex-row items-center gap-4 text-sm">
        <p class="flex-1">
          En acceptant les cookies, vous nous aidez à améliorer nos guides d'assurance pour mieux vous informer. Vos données restent anonymes.
        </p>
        <div class="flex gap-3 shrink-0 items-center">
          <button
            id="cookie-accept"
            class="px-5 py-2.5 rounded-lg bg-coral hover:bg-coral/90 font-medium transition-colors cursor-pointer"
          >
            OK, j'accepte
          </button>
          <button
            id="cookie-reject"
            class="px-3 py-2 text-white/50 hover:text-white/80 text-sm transition-colors cursor-pointer"
          >
            Non merci
          </button>
        </div>
      </div>
    </div>

    <script is:inline>
      (function() {
        var consent = localStorage.getItem('covelia_consent');
        if (consent) return;

        var banner = document.getElementById('cookie-banner');
        setTimeout(function() {
          banner.classList.add('visible');
        }, 1000);

        document.getElementById('cookie-accept').addEventListener('click', function() {
          localStorage.setItem('covelia_consent', 'granted');
          gtag('consent', 'update', { analytics_storage: 'granted' });
          banner.classList.remove('visible');
        });

        document.getElementById('cookie-reject').addEventListener('click', function() {
          localStorage.setItem('covelia_consent', 'denied');
          banner.classList.remove('visible');
        });
      })();
    </script>
  </body>
</html>
