---
import BaseLayout from "./BaseLayout.astro";
import SchemaOrg from "../components/SchemaOrg.astro";
import TableOfContents from "../components/TableOfContents.astro";
import SidebarCTA from "../components/SidebarCTA.astro";
import MobileCTABar from "../components/MobileCTABar.astro";
import MobileTOC from "../components/MobileTOC.astro";
import { getCollection } from "astro:content";

interface Author {
  name: string;
  credentials?: string;
}

interface FAQItem {
  question: string;
  answer: string;
}

interface ResolvedRelatedArticle {
  title: string;
  slug: string;
  category: string;
  description: string;
}

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Frontmatter {
  title: string;
  description: string;
  datePublished: string;
  dateModified?: string;
  author: Author;
  category: string;
  pillar: string;
  pillarSlug: string;
  faq?: FAQItem[];
  affiliateDisclosure?: boolean;
  estimatedReadingTime: number;
  tags?: string[];
  relatedArticles?: string[];
  image?: string;
}

interface Props {
  frontmatter: Frontmatter;
  headings: Heading[];
}

const { frontmatter, headings } = Astro.props;

const {
  title,
  description,
  datePublished,
  dateModified,
  author,
  category,
  pillar,
  pillarSlug,
  faq,
  affiliateDisclosure,
  estimatedReadingTime,
  relatedArticles: relatedSlugs,
  image,
} = frontmatter;

// Resolve related article slugs to full article data
let resolvedRelatedArticles: ResolvedRelatedArticle[] = [];
if (relatedSlugs && relatedSlugs.length > 0) {
  const collections = await Promise.all([
    getCollection("assurance-auto"),
    getCollection("assurance-habitation"),
    getCollection("mutuelle-sante"),
    getCollection("assurance-emprunteur"),
    getCollection("reglementation"),
  ]);
  const allArticles = collections.flat();

  resolvedRelatedArticles = relatedSlugs
    .map((slug) => {
      const found = allArticles.find((a) => a.id === slug);
      if (!found) return null;
      return {
        title: found.data.title,
        slug: found.id,
        category: found.data.category,
        description: found.data.description,
      };
    })
    .filter((a): a is ResolvedRelatedArticle => a !== null);
}

const formattedDate = new Date(datePublished).toLocaleDateString("fr-FR", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const formattedModifiedDate = dateModified
  ? new Date(dateModified).toLocaleDateString("fr-FR", {
      year: "numeric",
      month: "long",
      day: "numeric",
    })
  : null;

// Build schemas array
const schemas: Array<{ type: string; data?: unknown }> = [
  {
    type: "Article",
    data: {
      headline: title,
      description,
      datePublished,
      dateModified: dateModified || datePublished,
      author,
      image,
    },
  },
  {
    type: "BreadcrumbList",
    data: [
      { name: "Accueil", url: "https://covelia.fr/" },
      { name: pillar, url: `https://covelia.fr/${pillarSlug}/` },
      { name: title, url: Astro.url.href },
    ],
  },
];

if (faq && faq.length > 0) {
  schemas.push({ type: "FAQPage", data: faq });
}
---

<BaseLayout title={title} description={description} image={image}>
  <SchemaOrg schemas={schemas as any} />

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8">
    <!-- Breadcrumbs -->
    <nav aria-label="Fil d'Ariane" class="mb-8">
      <ol class="flex items-center gap-2 text-sm text-navy-light">
        <li>
          <a href="/" class="hover:text-coral transition-colors">Accueil</a>
        </li>
        <li aria-hidden="true" class="select-none">/</li>
        <li>
          <a
            href={`/${pillarSlug}/`}
            class="hover:text-coral transition-colors"
          >
            {pillar}
          </a>
        </li>
        <li aria-hidden="true" class="select-none">/</li>
        <li class="text-navy font-medium truncate max-w-[200px]" aria-current="page">
          {title}
        </li>
      </ol>
    </nav>

    <div class="flex flex-col lg:flex-row gap-8 lg:gap-12">
      <!-- Sidebar LEFT (desktop only) -->
      <aside
        class="hidden lg:block w-64 shrink-0"
        aria-label="Navigation article"
      >
        <div class="sticky top-24 flex flex-col gap-6 max-h-[calc(100vh-8rem)]">
          <div class="overflow-y-auto flex-shrink min-h-0">
            <TableOfContents headings={headings} />
          </div>
          <div class="flex-shrink-0">
            <SidebarCTA category={category} />
          </div>
        </div>
      </aside>

      <!-- Main content column -->
      <article class="min-w-0 max-w-3xl flex-1">
        <!-- Article header -->
        <header class="mb-10">
          <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-navy leading-tight mb-4">
            {title}
          </h1>

          <p class="text-lg text-navy-light mb-6">{description}</p>

          <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-navy-light">
            <div class="flex items-center gap-1.5">
              <span class="font-medium text-navy">{author.name}</span>
              {author.credentials && (
                <span class="text-navy-light">· {author.credentials}</span>
              )}
            </div>
            <span aria-hidden="true" class="hidden sm:inline">·</span>
            <time datetime={datePublished}>{formattedDate}</time>
            {formattedModifiedDate && (
              <>
                <span aria-hidden="true" class="hidden sm:inline">·</span>
                <span>
                  Mis à jour le <time datetime={dateModified}>{formattedModifiedDate}</time>
                </span>
              </>
            )}
            <span aria-hidden="true" class="hidden sm:inline">·</span>
            <span>{estimatedReadingTime} min de lecture</span>
          </div>
        </header>

        <!-- Mobile TOC -->
        <MobileTOC headings={headings} />

        <!-- MDX content slot -->
        <div class="prose prose-lg max-w-none prose-headings:text-navy prose-headings:font-bold prose-a:text-coral prose-a:no-underline hover:prose-a:underline prose-strong:text-navy prose-blockquote:border-coral prose-blockquote:text-navy-light">
          <slot />
        </div>

        <!-- Affiliate disclosure -->
        {affiliateDisclosure && (
          <aside class="mt-12 rounded-xl border border-coral-light bg-coral-light/20 p-5 text-sm text-navy-light">
            <p>
              <strong class="text-navy">Transparence :</strong> Certains liens de cet article sont des liens affiliés.
              Si vous souscrivez via ces liens, nous percevons une commission sans surcoût pour vous.
              Cela nous aide à maintenir ce site indépendant et gratuit.
            </p>
          </aside>
        )}

        <!-- Related articles -->
        {resolvedRelatedArticles.length > 0 && (
          <section class="mt-16" aria-labelledby="related-heading">
            <h2 id="related-heading" class="text-2xl font-bold text-navy mb-6">
              Articles similaires
            </h2>
            <div class="grid gap-4 sm:grid-cols-2">
              {resolvedRelatedArticles.map((article) => (
                <a
                  href={`/${article.category}/${article.slug}/`}
                  class="group rounded-xl border border-gray-200 p-5 transition-all hover:border-coral hover:shadow-md"
                >
                  <h3 class="font-semibold text-navy group-hover:text-coral transition-colors">
                    {article.title}
                  </h3>
                  {article.description && (
                    <p class="mt-2 text-sm text-navy-light line-clamp-2">
                      {article.description}
                    </p>
                  )}
                </a>
              ))}
            </div>
          </section>
        )}

        <!-- CTA back to hub -->
        <div class="mt-12 mb-20 lg:mb-0 text-center">
          <a
            href={`/${pillarSlug}/`}
            class="inline-flex items-center gap-2 rounded-full bg-coral px-6 py-3 font-semibold text-white transition-colors hover:bg-coral-dark"
          >
            <span aria-hidden="true">&larr;</span>
            Retour au guide {pillar}
          </a>
        </div>
      </article>
    </div>
  </div>

  <!-- Mobile sticky CTA bar -->
  <MobileCTABar category={category} />
</BaseLayout>
